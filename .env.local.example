# ── Admin ──────────────────────────────────────────────
# Password to access /admin (set something strong)
ADMIN_PASSWORD=telstraconnectedpod

# ── App ────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Microsoft / Outlook ────────────────────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Add a Web redirect URI: http://localhost:3000/api/outlook/callback
# Grant delegated permissions: Calendars.ReadWrite, offline_access
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=common
# Calendar to sync to (leave blank to use the default calendar)
OUTLOOK_CALENDAR_ID=
